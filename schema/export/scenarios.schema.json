{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/swarmproof/agent-postmortems/schema/export/scenarios.schema.json",
  "title": "agent-postmortems stampede scenarios export",
  "type": "object",
  "additionalProperties": false,
  "required": ["export_schema_version", "generated_at", "taxonomy_version", "count", "scenarios"],
  "properties": {
    "export_schema_version": { "type": "string", "const": "1.0" },
    "generated_at": { "type": "string" },
    "taxonomy_version": { "type": "string" },
    "count": { "type": "integer", "minimum": 0 },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["incident_id", "failure_class", "attack_vector", "system_profile", "trigger_shape", "expected_failure", "success_criteria", "source"],
        "properties": {
          "incident_id": { "type": "string" },
          "failure_class": { "type": "string" },
          "attack_vector": { "type": "string" },
          "system_profile": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "framework": { "type": "string" },
              "tools": { "type": "array", "items": { "type": "string" } },
              "autonomy_level": { "type": "string" }
            }
          },
          "trigger_shape": { "type": "string", "description": "Natural language only — never a weaponized payload (NG5)." },
          "expected_failure": { "type": "string" },
          "success_criteria": { "type": "string" },
          "source": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
