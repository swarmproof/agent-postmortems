{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/swarmproof/agent-postmortems/schema/export/incidents.schema.json",
  "title": "agent-postmortems incidents export",
  "type": "object",
  "additionalProperties": false,
  "required": ["export_schema_version", "generated_at", "taxonomy_version", "count", "incidents"],
  "properties": {
    "export_schema_version": { "type": "string", "const": "1.0" },
    "generated_at": { "type": "string" },
    "taxonomy_version": { "type": "string" },
    "count": { "type": "integer", "minimum": 0 },
    "incidents": {
      "type": "array",
      "description": "Each element is a full validated incident record (incident.schema.json).",
      "items": { "type": "object", "required": ["incident_id", "primary_failure_class"] }
    }
  }
}
