{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/swarmproof/agent-postmortems/schema/export/seeds.schema.json",
  "title": "agent-postmortems costbomb seeds export",
  "type": "object",
  "additionalProperties": false,
  "required": ["export_schema_version", "generated_at", "taxonomy_version", "count", "seeds"],
  "properties": {
    "export_schema_version": { "type": "string", "const": "1.0" },
    "generated_at": { "type": "string" },
    "taxonomy_version": { "type": "string" },
    "count": { "type": "integer", "minimum": 0 },
    "seeds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["incident_id", "failure_class", "cost_dimension", "observed_cost_usd", "seed_shape", "guardrail_under_test", "source"],
        "properties": {
          "incident_id": { "type": "string" },
          "failure_class": { "type": "string" },
          "cost_dimension": { "type": "string" },
          "observed_cost_usd": { "type": ["number", "null"] },
          "seed_shape": { "type": "string", "description": "Natural language only — never a weaponized payload (NG5)." },
          "guardrail_under_test": { "type": "string" },
          "source": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
