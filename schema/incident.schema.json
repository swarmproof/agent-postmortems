{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/swarmproof/agent-postmortems/schema/incident.schema.json",
  "title": "Agent Incident Post-Mortem",
  "type": "object",
  "required": ["incident_id", "date", "system", "failure_class", "trigger", "blast_radius", "root_cause", "detection", "recovery", "prevention", "sources"],
  "properties": {
    "incident_id": { "type": "string", "description": "Stable slug, e.g. 2025-whatsapp-mcp-exfiltration" },
    "date": { "type": "string", "format": "date" },
    "system": {
      "type": "object",
      "description": "The stack involved",
      "properties": {
        "framework": { "type": "string" },
        "models": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } }
      }
    },
    "failure_class": {
      "type": "string",
      "description": "Taxonomy term",
      "enum": ["runaway-loop", "tool-misuse", "prompt-injection", "double-side-effect", "cost-blowup", "data-exfiltration", "unsafe-action", "other"]
    },
    "trigger": { "type": "string" },
    "blast_radius": {
      "type": "object",
      "properties": {
        "cost_usd": { "type": ["number", "null"] },
        "data": { "type": "string" },
        "user_harm": { "type": "string" }
      }
    },
    "root_cause": { "type": "string" },
    "detection": { "type": "string" },
    "recovery": { "type": "string" },
    "prevention": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "Every incident needs at least one public, linkable source. No rumors.",
      "items": { "type": "string", "format": "uri" }
    }
  }
}
