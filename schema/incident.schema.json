{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/swarmproof/agent-postmortems/schema/incident.schema.json",
  "title": "Agent Incident Post-Mortem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "incident_id", "title", "date", "system",
    "primary_failure_class", "failure_classes", "incident_type",
    "trigger", "blast_radius", "root_cause", "detection", "recovery",
    "prevention", "sources"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0", "description": "Standard version this record conforms to." },
    "taxonomy_version": { "type": "string", "description": "Version of taxonomy.yaml used for failure_classes.", "examples": ["1.0"] },

    "incident_id": {
      "type": "string",
      "pattern": "^[0-9]{4}-[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Stable, immutable slug: <year>-<kebab>. e.g. 2025-whatsapp-mcp-tool-poisoning"
    },
    "title": { "type": "string", "minLength": 8, "maxLength": 140, "description": "Neutral, factual one-line title." },
    "summary": { "type": "string", "maxLength": 500, "description": "Neutral 1–3 sentence factual summary. No editorializing." },
    "date": { "type": "string", "format": "date", "description": "Date the incident occurred or was first publicly disclosed (YYYY-MM-DD)." },
    "last_updated": { "type": "string", "format": "date" },

    "incident_type": {
      "type": "string",
      "enum": ["incident", "hazard"],
      "description": "incident = realized harm in the wild; hazard = demonstrated PoC / near-miss that could plausibly cause harm (OECD-style)."
    },
    "status": {
      "type": "string",
      "enum": ["preliminary", "factual", "final"],
      "default": "factual",
      "description": "Report maturity (NTSB-style). 'disputed' facts are handled via confidence, not status."
    },
    "confidence": {
      "type": "string",
      "enum": ["reported", "corroborated", "confirmed", "disputed"],
      "description": "reported=single source; corroborated=multiple independent; confirmed=first-party/vendor/court-confirmed; disputed=facts contested."
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "moderate", "low", "informational"],
      "description": "Impact band. See severity_rationale for justification; do NOT infer a numeric score."
    },
    "severity_rationale": { "type": "string" },

    "system": {
      "type": "object",
      "additionalProperties": false,
      "description": "The stack involved. Name systems factually as data; do not editorialize.",
      "properties": {
        "framework": { "type": "string", "description": "e.g. LangGraph, CrewAI, Claude Code, custom, n/a" },
        "models": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" }, "description": "e.g. whatsapp-mcp, github-mcp, aws-cli, filesystem" },
        "vendor": { "type": "string", "description": "Operating org/vendor of the deployed system, if applicable." },
        "autonomy_level": {
          "type": "string",
          "enum": ["suggest", "human-in-the-loop", "supervised-autonomous", "fully-autonomous", "unknown"],
          "description": "How much the agent could act without human approval at time of incident."
        }
      }
    },

    "primary_failure_class": { "$ref": "#/$defs/failureClass" },
    "failure_classes": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered chain of failure classes; the causal sequence. First SHOULD equal primary_failure_class.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["class"],
        "properties": {
          "class": { "$ref": "#/$defs/failureClass" },
          "subclass": { "type": "string", "description": "Subclass from taxonomy.yaml under this class." }
        }
      }
    },
    "attack_vector": {
      "type": "string",
      "enum": ["direct-user", "untrusted-content", "tool-metadata", "supply-chain", "multimodal", "self-induced", "n-a"],
      "description": "For security-relevant incidents: how the failure was induced (VERIS action.vector analogue)."
    },

    "causation": {
      "type": "object",
      "additionalProperties": false,
      "description": "MIT AI Risk Repository causal dimensions.",
      "properties": {
        "entity": { "type": "string", "enum": ["human", "ai", "both", "unknown"] },
        "intentionality": { "type": "string", "enum": ["intentional", "unintentional", "mixed", "unknown"] },
        "timing": { "type": "string", "enum": ["pre-deployment", "post-deployment", "unknown"] }
      }
    },

    "trigger": { "type": "string", "description": "What set it off — described as a (near-)reproducible input/condition where the public source allows." },
    "root_cause": { "type": "string", "description": "The underlying cause. Blameless: systemic, not personal." },
    "contributing_factors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "2–5 systemic contributing factors (SRE blameless style)."
    },
    "detection": { "type": "string", "description": "How it was noticed." },
    "recovery": { "type": "string", "description": "How it was stopped/fixed." },
    "prevention": { "type": "string", "description": "What would prevent recurrence." },

    "blast_radius": {
      "type": "object",
      "additionalProperties": false,
      "description": "Structured impact.",
      "properties": {
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "amount_usd": { "type": ["number", "null"] },
            "amount_usd_max": { "type": ["number", "null"], "description": "Upper bound if reported as a range." },
            "estimated": { "type": "boolean", "default": false }
          }
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "records": { "type": ["integer", "null"] },
            "classification": { "type": "string", "enum": ["public", "internal", "confidential", "pii", "credentials", "unknown", "n-a"] },
            "description": { "type": "string" }
          }
        },
        "user_harm": {
          "type": "object",
          "additionalProperties": false,
          "description": "Harm categories from arXiv 2501.17037. Never identify individuals beyond public sources.",
          "properties": {
            "categories": {
              "type": "array",
              "items": { "type": "string", "enum": ["physical", "environmental", "property", "psychological", "reputational", "economic", "legal-regulatory", "human-rights", "none-reported"] }
            },
            "affected_count": { "type": ["integer", "null"] },
            "description": { "type": "string" }
          }
        },
        "scope": { "type": "string", "description": "Breadth, e.g. 'single user', '~1M extension installs', '30 orgs targeted'." },
        "reversibility": { "type": "string", "enum": ["reversible", "partially-reversible", "irreversible", "unknown"] }
      }
    },

    "timeline": {
      "type": "array",
      "description": "Optional ordered events.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["event"],
        "properties": {
          "at": { "type": "string", "description": "ISO 8601 timestamp or date, if known." },
          "event": { "type": "string" }
        }
      }
    },

    "external_ids": {
      "type": "object",
      "additionalProperties": false,
      "description": "Cross-references to other databases (de-dup, not clone).",
      "properties": {
        "aiid": { "type": ["integer", "string"] },
        "oecd_aim": { "type": "string" },
        "aiaaic": { "type": "string" }
      }
    },
    "cve": { "type": "array", "items": { "type": "string", "pattern": "^CVE-[0-9]{4}-[0-9]+$" } },
    "cwe": { "type": "array", "items": { "type": "string", "pattern": "^CWE-[0-9]+$" } },
    "related_incidents": { "type": "array", "items": { "type": "string", "description": "Other incident_ids." } },
    "tags": { "type": "array", "items": { "type": "string" } },

    "submitted_by": { "type": "string", "description": "Contributor handle/name (optional)." },

    "sources": {
      "type": "array",
      "minItems": 1,
      "description": "REQUIRED. ≥1 public, linkable source. No rumors. Structured for permanence and citability.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url", "type"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "publisher": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["primary-research", "vendor-disclosure", "vendor-response", "regulatory-court", "news", "academic", "social-primary", "other"],
            "description": "primary-research=the researcher writeup; vendor-response=the named vendor's reply (supports neutrality/right-of-reply)."
          },
          "date_accessed": { "type": "string", "format": "date" },
          "archive_url": { "type": "string", "format": "uri", "description": "Wayback/permanent snapshot. Auto-generated in CI if absent (REQ-C5)." }
        }
      }
    },

    "machine_export": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional hints that shape the stampede/costbomb export projections. If absent, export derives sensible defaults.",
      "properties": {
        "replayable": { "type": "boolean", "description": "True if trigger can be shaped into a scenario/seed." },
        "stampede_scenario_hint": { "type": "string" },
        "costbomb_seed_hint": { "type": "string" }
      }
    }
  },

  "$defs": {
    "failureClass": {
      "type": "string",
      "enum": [
        "prompt-injection", "jailbreak", "tool-misuse", "unsafe-action",
        "data-exfiltration", "excessive-agency", "runaway-loop", "cost-blowup",
        "double-side-effect", "hallucination", "reward-hacking", "goal-misalignment",
        "memory-context-poisoning", "supply-chain-compromise", "insecure-output",
        "multi-agent-failure", "task-failure", "autonomous-misuse", "other"
      ],
      "description": "Top-level failure class. See taxonomy.yaml for subclasses and cairn alignment."
    }
  }
}
